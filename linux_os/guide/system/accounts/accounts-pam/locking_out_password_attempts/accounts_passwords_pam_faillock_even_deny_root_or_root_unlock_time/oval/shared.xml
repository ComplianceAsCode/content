<def-group>
  <definition class="compliance" id="{{{ rule_id }}}" version="1">
    {{{ oval_metadata("The root account should be included in the account lockout policy.
      Either the even_deny_root option should be set or root_unlock_time should be set to
      the required minimum value or greater.", rule_title=rule_title) }}}
    <criteria operator="AND" comment="Check the proper configuration of pam_faillock.so">
      <criteria operator="AND" comment="Check if pam_faillock.so is properly enabled">
        <criteria operator="AND"
                  comment="Count occurrences of pam_unix.so in system-auth and password-auth">
          <criterion
              test_ref="test_{{{ rule_id }}}_system_pam_unix_auth"
              comment="pam_unix.so appears only once in auth section of system-auth"/>
          <criterion
              test_ref="test_{{{ rule_id }}}_password_pam_unix_auth"
              comment="pam_unix.so appears only once in auth section of password-auth"/>
        </criteria>

        <criteria operator="AND" comment="Check common definition of pam_faillock.so">
          <criterion
              test_ref="test_{{{ rule_id }}}_system_pam_faillock_auth"
              comment="pam_faillock.so is properly defined in auth section of system-auth"/>
          <criterion
              test_ref="test_{{{ rule_id }}}_system_pam_faillock_account"
              comment="pam_faillock.so is properly defined in account section of system-auth"/>
          <criterion
              test_ref="test_{{{ rule_id }}}_password_pam_faillock_auth"
              comment="pam_faillock.so is properly defined in auth section of password-auth"/>
          <criterion
              test_ref="test_{{{ rule_id }}}_password_pam_faillock_account"
              comment="pam_faillock.so is properly defined in account section of password-auth"/>
        </criteria>
      </criteria>

      <criteria operator="OR"
                comment="Check even_deny_root is set or root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time">
        <criteria operator="OR"
                  comment="Check expected value for pam_faillock.so even_deny_root parameter">
          <criteria operator="AND"
                    comment="Check expected pam_faillock.so even_deny_root parameter in pam files">
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_pamd_system"
                comment="Check the even_deny_root parameter in auth section of system-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_pamd_password"
                comment="Check the even_deny_root parameter in auth section of password-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_no_faillock_conf"
                comment="Ensure {{{ pam_faillock_conf_path }}} is not used together with pam files"/>
          </criteria>
          <criteria operator="AND"
                comment="Check expected pam_faillock.so even_deny_root parameter in {{{ pam_faillock_conf_path }}}">
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_no_pamd_system"
                comment="Check the even_deny_root parameter is not present system-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_no_pamd_password"
                comment="Check the even_deny_root parameter is not present password-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_even_deny_root_parameter_faillock_conf"
                comment="Ensure the even_deny_root parameter is present in {{{ pam_faillock_conf_path }}}"/>
          </criteria>
        </criteria>

        <criteria operator="OR"
                  comment="Check expected value for pam_faillock.so root_unlock_time parameter">
          <criteria operator="AND"
                    comment="Check pam_faillock.so root_unlock_time parameter in pam files">
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_pamd_system"
                comment="Check root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time in auth section of system-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_pamd_password"
                comment="Check root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time in auth section of password-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_no_faillock_conf"
                comment="Ensure root_unlock_time is not in {{{ pam_faillock_conf_path }}} together with pam files"/>
          </criteria>
          <criteria operator="AND"
                comment="Check pam_faillock.so root_unlock_time parameter in {{{ pam_faillock_conf_path }}}">
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_no_pamd_system"
                comment="Check root_unlock_time is not present in system-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_no_pamd_password"
                comment="Check root_unlock_time is not present in password-auth file"/>
            <criterion
                test_ref="test_{{{ rule_id }}}_root_unlock_time_parameter_faillock_conf"
                comment="Ensure root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time in {{{ pam_faillock_conf_path }}}"/>
          </criteria>
        </criteria>
      </criteria>
    </criteria>
  </definition>

  <!-- Regex variables -->
  <constant_variable id="var_{{{ rule_id }}}_pam_unix_regex"
                datatype="string" version="1"
                comment="regex to identify pam_unix.so in auth section of pam files">
    <value>^[\s]*auth\N+pam_unix\.so</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_pam_faillock_auth_regex"
                datatype="string" version="1"
                comment="regex to identify pam_faillock.so entries in auth section of pam files">
    <value>^[\s]*auth[\s]+(required|\[(?=.*?\bsuccess=ok\b)(?=.*?\bnew_authtok_reqd=ok\b)(?=.*?\bignore=ignore\b)(?=.*?\bdefault=bad\b).*\])[\s]+pam_faillock\.so[\s\w\d=]+preauth[\s\S]*^[\s]*auth[\s]+(sufficient|\[(?=.*\bsuccess=done\b)(?=.*?\bnew_authtok_reqd=done\b)(?=.*?\bdefault=ignore\b).*\])[\s]+pam_unix\.so[\s\S]*^[\s]*auth[\s]+(required|\[(?=.*?\bsuccess=ok\b)(?=.*?\bnew_authtok_reqd=ok\b)(?=.*?\bignore=ignore\b)(?=.*?\bdefault=bad\b).*\])[\s]+pam_faillock\.so[\s\w\d=]+authfail</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_pam_faillock_account_regex"
                datatype="string" version="1"
                comment="regex to identify pam_faillock.so entry in account section of pam files">
    <value>^[\s]*account[\s]+(required|\[(?=.*?\bsuccess=ok\b)(?=.*?\bnew_authtok_reqd=ok\b)(?=.*?\bignore=ignore\b)(?=.*?\bdefault=bad\b).*\])[\s]+pam_faillock\.so[\s\S]*^[\s]*account[\s]+(required|\[(?=.*?\bsuccess=ok\b)(?=.*?\bnew_authtok_reqd=ok\b)(?=.*?\bignore=ignore\b)(?=.*?\bdefault=bad\b).*\])[\s]+pam_unix\.so</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_even_deny_root_parameter_regex"
                datatype="string" version="1"
                comment="regex to identify even_deny_root in auth section of pam files">
    <value>^[\s]*auth[\s]+.+[\s]+pam_faillock.so[\s]+[^\n]*even_deny_root</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_even_deny_root_faillock_conf_regex"
                datatype="string" version="1"
                comment="regex to identify even_deny_root in {{{ pam_faillock_conf_path }}}">
    <value>^[\s]*even_deny_root</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_root_unlock_time_parameter_regex"
                datatype="string" version="1"
                comment="regex to identify root_unlock_time in auth section of pam files">
    <value>^[\s]*auth[\s]+.+[\s]+pam_faillock.so[\s]+[^\n]*root_unlock_time=([0-9]+)</value>
  </constant_variable>

  <constant_variable id="var_{{{ rule_id }}}_root_unlock_time_faillock_conf_regex"
                datatype="string" version="1"
                comment="regex to identify root_unlock_time in {{{ pam_faillock_conf_path }}}">
    <value>^[\s]*root_unlock_time[\s]*=[\s]*([0-9]+)</value>
  </constant_variable>

  <!-- PAM structure checks: pam_unix.so in system-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_system_pam_unix_auth"
        comment="Get the second and subsequent occurrences of pam_unix.so in auth section of system-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/system-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
                 var_ref="var_{{{ rule_id }}}_pam_unix_regex"/>
    <ind:instance datatype="int" operation="greater than">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_system_pam_unix_auth"
        comment="No more than one pam_unix.so is expected in auth section of system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_system_pam_unix_auth"/>
  </ind:textfilecontent54_test>

  <!-- PAM structure checks: pam_unix.so in password-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_password_pam_unix_auth"
        comment="Get the second and subsequent occurrences of pam_unix.so in auth section of password-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
                 var_ref="var_{{{ rule_id }}}_pam_unix_regex"/>
    <ind:instance datatype="int" operation="greater than">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_password_pam_unix_auth"
        comment="No more than one pam_unix.so is expected in auth section of password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_password_pam_unix_auth"/>
  </ind:textfilecontent54_test>

  <!-- PAM structure checks: pam_faillock.so in system-auth (auth section) -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_system_pam_faillock_auth"
        comment="Check common definition of pam_faillock.so in auth section of system-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/system-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
                 var_ref="var_{{{ rule_id }}}_pam_faillock_auth_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="only_one_exists" version="1"
        id="test_{{{ rule_id }}}_system_pam_faillock_auth"
        comment="One and only one pattern occurrence is expected in auth section of system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_system_pam_faillock_auth"/>
  </ind:textfilecontent54_test>

  <!-- PAM structure checks: pam_faillock.so in system-auth (account section) -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_system_pam_faillock_account"
        comment="Check common definition of pam_faillock.so in account section of system-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/system-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
              var_ref="var_{{{ rule_id }}}_pam_faillock_account_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="only_one_exists" version="1"
      id="test_{{{ rule_id }}}_system_pam_faillock_account"
      comment="One and only one pattern occurrence is expected in account section of system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_system_pam_faillock_account"/>
  </ind:textfilecontent54_test>

  <!-- PAM structure checks: pam_faillock.so in password-auth (auth section) -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_password_pam_faillock_auth"
        comment="Check common definition of pam_faillock.so in auth section of password-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
                 var_ref="var_{{{ rule_id }}}_pam_faillock_auth_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="only_one_exists" version="1"
        id="test_{{{ rule_id }}}_password_pam_faillock_auth"
        comment="One and only one pattern occurrence is expected in auth section of password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_password_pam_faillock_auth"/>
  </ind:textfilecontent54_test>

  <!-- PAM structure checks: pam_faillock.so in password-auth (account section) -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_password_pam_faillock_account"
        comment="Check common definition of pam_faillock.so in account section of password-auth">
    <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
              var_ref="var_{{{ rule_id }}}_pam_faillock_account_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="only_one_exists" version="1"
        id="test_{{{ rule_id }}}_password_pam_faillock_account"
    comment="One and only one pattern occurrence is expected in account section of password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_password_pam_faillock_account"/>
  </ind:textfilecontent54_test>

  <!-- even_deny_root parameter checks in system-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_system"
        comment="Get the pam_faillock.so even_deny_root parameter from system-auth file">
    <ind:filepath operation="pattern match">^/etc/pam.d/system-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
            var_ref="var_{{{ rule_id }}}_even_deny_root_parameter_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_pamd_system"
        comment="Check the expected even_deny_root parameter in system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_system"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_no_pamd_system"
        comment="Check the absence of even_deny_root parameter in system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_system"/>
  </ind:textfilecontent54_test>

  <!-- even_deny_root parameter checks in password-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_password"
        comment="Get the pam_faillock.so even_deny_root parameter from password-auth file">
    <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
            var_ref="var_{{{ rule_id }}}_even_deny_root_parameter_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_pamd_password"
        comment="Check the expected even_deny_root parameter in password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_password"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_no_pamd_password"
        comment="Check the absence of even_deny_root parameter in password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_pamd_password"/>
  </ind:textfilecontent54_test>

  <!-- even_deny_root parameter checks in faillock.conf -->
  <ind:textfilecontent54_object version="1"
      id="object_{{{ rule_id }}}_even_deny_root_parameter_faillock_conf"
      comment="Try to get the even_deny_root parameter from {{{ pam_faillock_conf_path }}}">
    <ind:filepath operation="pattern match">^{{{ pam_faillock_conf_path }}}$</ind:filepath>
    <ind:pattern operation="pattern match"
          var_ref="var_{{{ rule_id }}}_even_deny_root_faillock_conf_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_faillock_conf"
        comment="Check the expected even_deny_root parameter in {{{ pam_faillock_conf_path }}}">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_faillock_conf"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_even_deny_root_parameter_no_faillock_conf"
        comment="Check the absence of even_deny_root parameter in {{{ pam_faillock_conf_path }}}">
    <ind:object object_ref="object_{{{ rule_id }}}_even_deny_root_parameter_faillock_conf"/>
  </ind:textfilecontent54_test>

  <!-- root_unlock_time parameter checks in system-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_system"
        comment="Get the pam_faillock.so root_unlock_time parameter from system-auth file">
    <ind:filepath operation="pattern match">^/etc/pam.d/system-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
            var_ref="var_{{{ rule_id }}}_root_unlock_time_parameter_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_pamd_system"
        comment="Check root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time in auth section of system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_system"/>
    <ind:state state_ref="state_{{{ rule_id }}}_root_unlock_time_lower_bound"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_no_pamd_system"
        comment="Check the absence of root_unlock_time parameter in system-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_system"/>
  </ind:textfilecontent54_test>

  <!-- root_unlock_time parameter checks in password-auth -->
  <ind:textfilecontent54_object version="1"
        id="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_password"
        comment="Get the pam_faillock.so root_unlock_time parameter from password-auth file">
    <ind:filepath operation="pattern match">^/etc/pam.d/password-auth$</ind:filepath>
    <ind:pattern operation="pattern match"
            var_ref="var_{{{ rule_id }}}_root_unlock_time_parameter_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_pamd_password"
        comment="Check root_unlock_time >= var_accounts_passwords_pam_faillock_root_unlock_time in auth section of password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_password"/>
    <ind:state state_ref="state_{{{ rule_id }}}_root_unlock_time_lower_bound"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_no_pamd_password"
        comment="Check the absence of root_unlock_time parameter in password-auth">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_pamd_password"/>
  </ind:textfilecontent54_test>

  <!-- root_unlock_time parameter checks in faillock.conf -->
  <ind:textfilecontent54_object version="1"
      id="object_{{{ rule_id }}}_root_unlock_time_parameter_faillock_conf"
      comment="Get the root_unlock_time parameter from {{{ pam_faillock_conf_path }}}">
    <ind:filepath operation="pattern match">^{{{ pam_faillock_conf_path }}}$</ind:filepath>
    <ind:pattern operation="pattern match"
          var_ref="var_{{{ rule_id }}}_root_unlock_time_faillock_conf_regex"/>
    <ind:instance datatype="int" operation="equals">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_test check="all" check_existence="all_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_faillock_conf"
        comment="Check root_unlock_time >= 60 in {{{ pam_faillock_conf_path }}}">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_faillock_conf"/>
    <ind:state state_ref="state_{{{ rule_id }}}_root_unlock_time_lower_bound"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_test check="all" check_existence="none_exist" version="1"
        id="test_{{{ rule_id }}}_root_unlock_time_parameter_no_faillock_conf"
        comment="Check the absence of root_unlock_time parameter in {{{ pam_faillock_conf_path }}}">
    <ind:object object_ref="object_{{{ rule_id }}}_root_unlock_time_parameter_faillock_conf"/>
  </ind:textfilecontent54_test>

  <!-- External variable for root_unlock_time lower bound -->
  <external_variable id="var_accounts_passwords_pam_faillock_root_unlock_time" datatype="int"
                     comment="root_unlock_time minimum value" version="1"/>

  <!-- State for root_unlock_time lower bound check -->
  <ind:textfilecontent54_state version="1"
      id="state_{{{ rule_id }}}_root_unlock_time_lower_bound">
    <ind:subexpression datatype="int" operation="greater than or equal"
                       var_ref="var_accounts_passwords_pam_faillock_root_unlock_time"/>
  </ind:textfilecontent54_state>
</def-group>
