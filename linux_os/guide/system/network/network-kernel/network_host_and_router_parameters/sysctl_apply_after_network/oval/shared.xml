<def-group>
  <definition class="compliance" id="sysctl_apply_after_network" version="1">
    {{{ oval_metadata("Ensure systemd-sysctl.service has a drop-in override that adds network.target to its After= ordering.", rule_title=rule_title) }}}
    <criteria>
      <criterion comment="Check that a drop-in file sets After=network.target for systemd-sysctl.service"
                 test_ref="test_sysctl_apply_after_network"/>
    </criteria>
  </definition>

  <ind:textfilecontent54_test id="test_sysctl_apply_after_network" version="1"
      check="at least one" check_existence="at_least_one_exists"
      comment="Check that a drop-in file sets After=network.target for systemd-sysctl.service">
    <ind:object object_ref="object_sysctl_apply_after_network"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_object id="object_sysctl_apply_after_network" version="1">
    <ind:path>/etc/systemd/system/systemd-sysctl.service.d</ind:path>
    <ind:filename operation="pattern match">^.*\.conf$</ind:filename>
    <ind:pattern operation="pattern match">^After=.*network\.target</ind:pattern>
    <ind:instance datatype="int" operation="greater than or equal">1</ind:instance>
  </ind:textfilecontent54_object>
</def-group>
