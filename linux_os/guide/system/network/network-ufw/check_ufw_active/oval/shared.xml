<def-group>
  <definition class="compliance" id="{{{ rule_id }}}" version="1">
    {{{ oval_metadata("Verify ufw is active", rule_title=rule_title) }}}
    <criteria>
      <criterion comment="ufw is enabled in /etc/ufw/ufw.conf"
        test_ref="{{{ rule_id }}}_test_ufw_enabled" />
    </criteria>
  </definition>

  <ind:textfilecontent54_test check="all" check_existence="at_least_one_exists"
    id="{{{ rule_id }}}_test_ufw_enabled" version="1"
    comment="Check ENABLED=yes in /etc/ufw/ufw.conf">
    <ind:object object_ref="{{{ rule_id }}}_obj_ufw_enabled"/>
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_object id="{{{ rule_id }}}_obj_ufw_enabled" version="1">
    <ind:filepath>/etc/ufw/ufw.conf</ind:filepath>
    <ind:pattern operation="pattern match">^ENABLED=yes$</ind:pattern>
    <ind:instance datatype="int">1</ind:instance>
  </ind:textfilecontent54_object>
</def-group>
