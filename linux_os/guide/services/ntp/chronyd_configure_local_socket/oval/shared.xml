<def-group oval_version="5.11">
  <definition class="compliance" id="chronyd_configure_local_socket" version="1">
    {{{ oval_metadata("Ensure chrony-wait.service is configured to use Unix socket
      instead of network addresses.", rule_title=rule_title) }}}
    <criteria operator="OR">
      <criterion test_ref="test_chrony_wait_service_not_installed" comment="chrony-wait.service is not installed" />
      <criterion test_ref="test_chrony_wait_service_fixed" comment="check if chrony-wait.service has been fixed (KCS 7064388)" />
    </criteria>
  </definition>

  <unix:file_test id="test_chrony_wait_service_not_installed"
    comment="check if /usr/lib/systemd/system/chrony-wait.service does not exist"
    check="all" check_existence="none_exist" version="1">
    <unix:object object_ref="obj_chrony_wait_service_package" />
  </unix:file_test>

  <unix:file_object id="obj_chrony_wait_service_package" version="1">
    <unix:filepath>/usr/lib/systemd/system/chrony-wait.service</unix:filepath>
  </unix:file_object>

  <ind:textfilecontent54_test id="test_chrony_wait_service_fixed"
    comment="check if chrony-wait.service ExecStart does not use -h flag for network addresses"
    check="all" check_existence="at_least_one_exists" version="1">
    <ind:object object_ref="obj_chrony_wait_service_execstart" />
    <ind:state state_ref="state_chrony_wait_execstart_no_h_flag" />
  </ind:textfilecontent54_test>

  <ind:textfilecontent54_object id="obj_chrony_wait_service_execstart" version="1">
    <ind:filepath>/etc/systemd/system/chrony-wait.service</ind:filepath>
    <ind:pattern operation="pattern match">^ExecStart=(.*)$</ind:pattern>
    <ind:instance operation="greater than or equal" datatype="int">1</ind:instance>
  </ind:textfilecontent54_object>

  <ind:textfilecontent54_state id="state_chrony_wait_execstart_no_h_flag" version="1">
    <ind:subexpression operation="pattern match">^/usr/bin/chronyc\s+waitsync\s+\d+\s+[\d.]+\s+[\d.]+\s+\d+\s*$</ind:subexpression>
  </ind:textfilecontent54_state>
</def-group>
