---
extends: default
locale: en_US.UTF-8
yaml-files:
  - "*.yaml"
  - "*.yml"
  - "*.fmf"

# https://yamllint.readthedocs.io/en/stable/rules.html
rules:
  comments: disable
  comments-indentation: disable
  document-start: disable
  empty-lines:
    level: warning
  indentation:
    spaces: consistent
  line-length:
    max: 99
